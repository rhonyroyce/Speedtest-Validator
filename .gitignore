# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Project outputs (generated at runtime)
outputs/*.xlsx
outputs/*.docx
outputs/*.pdf

# Keep the outputs directory itself
!outputs/.gitkeep

# Scratch / temp data (AI Workbench pattern)
data/scratch/*
!data/scratch/.gitkeep

# Sensitive / large files
*.log
*.tmp

# AI Workbench
.nv-workbench/

# Input folder — ignore CIQ files and all subdirectories (site data)
input/*CIQ*
input/*ciq*
input/*/
